mundo {

    bloco pedra vida = 10;

    mostrar("Vida:", vida);

    spawnar pedra soma(a, b) {

        dropar a + b;
    }

    bloco pedra x = soma(5, 2);

    mostrar("Resultado:", x);

    bloco pedra i = 0;

    mina(i < 3) {

        mostrar(i);

        i = i + 1;
    }

    bloco fumaca nome = "";

    coletar(nome);

    mostrar("Jogador:", nome);
}